{
  "name": "codeanalyst-web",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc && vite build",
    "dev": "node scripts/dev.mjs",
    "gateway": "cd .. && uv run python -m gateway.app",
    "preview": "vite preview --host 127.0.0.1 --port 4173",
    "start": "vite --host 127.0.0.1 --port 4173",
    "test": "tsc --outDir dist && node --test tests/*.test.mjs",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "dompurify": "^3.2.6",
    "marked": "^15.0.12"
  },
  "devDependencies": {
    "typescript": "^5.8.3",
    "vite": "^7.2.4"
  }
}
